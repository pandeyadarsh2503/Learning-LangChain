# ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys
# cp .env.example .env
# ─────────────────────────────────────────────

# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq API Key (ultra-fast LLM inference)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LangSmith API Key (for tracing & observability)
# Get it from: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# Enable LangSmith tracing (set to "true" to activate)
LANGCHAIN_TRACING_V2=true

# LangSmith project name (optional, groups your traces)
LANGCHAIN_PROJECT=Learning-LangChain
